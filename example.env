export CLUSTER_CONTEXT=test
export DOCKER_REGISTRY=docker.io
export IMAGE=bborbe/lockbox
export KAFKA_BROKERS=localhost:9092
# LOCKBOX_ENCRYPTION_KEY: base64-encoded AES key (16 or 32 raw bytes) used to
# encrypt stored secrets at rest. Generate one with: openssl rand -base64 32
export LOCKBOX_ENCRYPTION_KEY=changeme-generate-with-openssl-rand--base64-32
# Alternatively, configure a keyring of ordered keys (primary first) for
# rotation. Set EXACTLY ONE of LOCKBOX_ENCRYPTION_KEY or LOCKBOX_ENCRYPTION_KEYS.
# The first key is the primary — new secrets are sealed with it; all keys
# remain present so existing ciphertext (any key) stays readable.
# export LOCKBOX_ENCRYPTION_KEYS=<new-base64-key>,<old-base64-key>
export SKELETON_PORT=8080
